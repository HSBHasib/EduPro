# Backend API URL (your EduPro-Server deployment URL)
NEXT_PUBLIC_API_URL=http://localhost:5000

# Frontend App URL (your Vercel deployment URL)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# MongoDB Connection String (from MongoDB Atlas)
MONGODB_URI=

# Better Auth Secret (generate a random string)
BETTER_AUTH_SECRET=

# Google OAuth (from Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ImgBB API Key (from https://api.imgbb.com/)
NEXT_PUBLIC_IMGBB_API_KEY=

# PDF.js Worker URL (optional, defaults to unpkg CDN)
NEXT_PUBLIC_PDF_WORKER_URL=
